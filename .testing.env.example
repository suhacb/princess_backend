APP_NAME=princess_backend
APP_ENV=testing
APP_KEY=base64:<INSERT APP KEY>
APP_DEBUG=true
APP_URL=http://localhost:10105
APP_PORT=10105

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=princess_test
DB_USERNAME=princess
DB_PASSWORD=<INSERT POSTGRES_PASSWORD>

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=array
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@princess.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

CORS_ALLOWED_ORIGINS=http://localhost:10100

AUTH_FRONTEND_URL="http://localhost"
AUTH_FRONTEND_PORT=9020
AUTH_BACKEND_URL="http://host.docker.internal"
AUTH_BACKEND_PORT=9025
APP_BACKEND_URL="http://host.docker.internal"
APP_BACKEND_PORT=10105
APP_FRONTEND_URL="http://localhost"
APP_FRONTEND_PORT=10100

E2E_TOKEN=

ZINC_BASE_URI=http://zincdb:4080
ZINC_USER=princess
ZINC_PASSWORD=<INSERT ZINC_FIRST_ADMIN_PASSWORD>

QDRANT_BASE_URL=http://qdrant:6333

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_MODEL_FAST=gemma4:e4b
OLLAMA_MODEL_SMART=gemma4:26b
OLLAMA_TIMEOUT=300

GARAGE_ACCESS_KEY_ID=<INSERT GARAGE_ACCESS_KEY_ID>
GARAGE_SECRET_ACCESS_KEY=<INSERT GARAGE_SECRET_ACCESS_KEY>
GARAGE_REGION=garage
GARAGE_ADMIN_URL=http://garage:3903
GARAGE_S3_BUCKET_PREFIX=princess-test-project
GARAGE_TEMPLATES_BUCKET=princess-templates
AWS_ENDPOINT=http://garage:3900

ONLYOFFICE_URL=http://onlyoffice
ONLYOFFICE_JWT_SECRET=<INSERT ONLYOFFICE_JWT_SECRET>
